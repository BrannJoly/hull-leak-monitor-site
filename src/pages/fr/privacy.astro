---
import BaseLayout from "../../components/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { routePaths, siteContent } from "../../i18n";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const locale = "fr";
const page = siteContent[locale].privacy;
---

<BaseLayout locale={locale} route="privacy" title={page.meta.title} description={page.meta.description}>
  <Header locale={locale} route="privacy" />

  <main class="bg-white">
    <section class="section-shell max-w-4xl py-16 sm:py-20">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight text-ink sm:text-5xl">
        {page.title}
      </h1>
      <div class="mt-8 space-y-7 text-base leading-8 text-ink/70">
        {page.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <a
        class="mt-10 inline-flex min-h-12 items-center justify-center rounded-md bg-ink px-5 text-base font-semibold text-white transition hover:bg-panel-black"
        href={`${base}${routePaths.home[locale]}#waitlist`}
      >
        {page.cta}
      </a>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
