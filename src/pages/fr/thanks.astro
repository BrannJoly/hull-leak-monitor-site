---
import BaseLayout from "../../components/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { routePaths, siteContent } from "../../i18n";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const locale = "fr";
const page = siteContent[locale].thanks;
---

<BaseLayout locale={locale} route="thanks" title={page.meta.title} description={page.meta.description}>
  <Header locale={locale} route="thanks" />

  <main class="bg-mist">
    <section class="section-shell grid min-h-[calc(82svh-4rem)] place-items-center py-16 text-center">
      <div class="max-w-2xl">
        <p class="eyebrow">{page.eyebrow}</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-ink sm:text-6xl">
          {page.title}
        </h1>
        <p class="mt-6 text-lg leading-8 text-ink/68">
          {page.body}
        </p>
        <a
          class="mt-8 inline-flex min-h-12 items-center justify-center rounded-md bg-ink px-5 text-base font-semibold text-white transition hover:bg-panel-black"
          href={`${base}${routePaths.home[locale]}`}
        >
          {page.cta}
        </a>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
