---
const brevoAction =
  "https://c7c6378c.sibforms.com/serve/MUIFACD-HlS2DfxGUEmfj3H4-iximMSTcykMwYyo86bE5vukwm79ZorM-gSH93nQPr-7AOOYo-sQFeaGmZk6T1VvgiZMbti4Airg_-YV1zl38CVeCKw8SnRXKm-sCJSFJ19h7TQD03Biuludua3OFrDUXD285f-aauAbV-2IkudSavW4N43XZPM5xBbEEDRLgjh8ZjY4pDiWESl8bg==";
---

<div
  id="error-message"
  class="sib-form-message-panel mb-4 hidden rounded-md border border-danger/30 bg-danger/10 p-4 text-sm font-medium text-danger"
>
  Your subscription could not be saved. Please try again.
</div>

<div
  id="success-message"
  class="sib-form-message-panel mb-4 hidden rounded-md border border-signal/30 bg-signal/10 p-4 text-sm font-medium text-ink"
>
  Your subscription has been successful.
</div>

<form
  id="sib-form"
  action={brevoAction}
  method="POST"
  data-type="subscription"
  class="rounded-lg border border-ink/10 bg-white p-5 shadow-lift sm:p-7"
>
  <label class="grid gap-2 text-sm font-semibold text-ink">
    Email
    <input
      class="min-h-12 rounded-md border border-ink/16 bg-mist px-4 text-base font-normal text-ink transition placeholder:text-ink/40 focus:border-signal focus:bg-white"
      type="email"
      id="EMAIL"
      name="EMAIL"
      autocomplete="email"
      placeholder="you@example.com"
      data-required="true"
      required
    />
  </label>

  <label class="mt-5 grid gap-2 text-sm font-semibold text-ink">
    Boat status <span class="font-normal text-ink/52">(optional)</span>
    <select
      class="min-h-12 rounded-md border border-ink/16 bg-mist px-4 text-base font-normal text-ink transition focus:border-signal focus:bg-white"
      name="BOAT_STATUS"
    >
      <option value="">Select one</option>
      <option value="1">Owner</option>
      <option value="2">Refit or survey</option>
      <option value="3">Builder or technician</option>
      <option value="4">Researching</option>
    </select>
  </label>

  <label class="mt-5 grid gap-2 text-sm font-semibold text-ink">
    What feature would you love to see? <span class="font-normal text-ink/52">(optional)</span>
    <textarea
      class="min-h-28 rounded-md border border-ink/16 bg-mist px-4 py-3 text-base font-normal text-ink transition placeholder:text-ink/40 focus:border-signal focus:bg-white"
      id="NOTES"
      name="NOTES"
      maxlength="200"
      placeholder="Optional"
    ></textarea>
  </label>

  <div class="mt-5">
    <script is:inline>
      window.handleCaptchaResponse = function () {
        var captcha = document.getElementById("sib-captcha");
        if (captcha) captcha.dispatchEvent(new Event("captchaChange"));
      };
    </script>
    <div
      class="cf-turnstile sib-visible-recaptcha"
      id="sib-captcha"
      data-sitekey="0x4AAAAAADRyp50AYVKzplhJ"
      data-callback="handleCaptchaResponse"
    >
    </div>
  </div>

  <div aria-hidden="true" class="hidden">
    <label>
      Leave this field empty
      <input type="text" name="email_address_check" tabindex="-1" autocomplete="off" />
    </label>
  </div>
  <input type="hidden" name="locale" value="en" />

  <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center">
    <button
      class="inline-flex min-h-12 items-center justify-center rounded-md bg-signal px-5 text-base font-semibold text-ink shadow-sm transition hover:bg-[#2f9f56]"
      type="submit"
    >
      Join the waitlist
    </button>
    <p class="text-sm leading-6 text-ink/62">
      Submits through Brevo.
    </p>
  </div>
</form>

<script is:inline>
  window.REQUIRED_CODE_ERROR_MESSAGE = "Please choose a country code";
  window.LOCALE = "en";
  window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE =
    "The information provided is invalid. Please review the field format and try again.";
  window.REQUIRED_ERROR_MESSAGE = "This field cannot be left blank. ";
  window.GENERIC_INVALID_MESSAGE =
    "The information provided is invalid. Please review the field format and try again.";
  window.INVALID_NUMBER = "The information provided is invalid. Please review the field format and try again.";
  window.INVALID_DATE = "Please enter a valid date";
  window.REQUIRED_MULTISELECT_MESSAGE = "Please select at least 1 option";
  window.translation = {
    common: {
      selectedList: "{quantity} list selected",
      selectedLists: "{quantity} lists selected",
      selectedOption: "{quantity} selected",
      selectedOptions: "{quantity} selected",
    },
  };
  window.AUTOHIDE = Boolean(0);
</script>

<script is:inline defer src="https://sibforms.com/forms/end-form/build/main.js"></script>
<script is:inline defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
