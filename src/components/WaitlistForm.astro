---
const brevoAction =
  "https://c7c6378c.sibforms.com/serve/MUIFACD-HlS2DfxGUEmfj3H4-iximMSTcykMwYyo86bE5vukwm79ZorM-gSH93nQPr-7AOOYo-sQFeaGmZk6T1VvgiZMbti4Airg_-YV1zl38CVeCKw8SnRXKm-sCJSFJ19h7TQD03Biuludua3OFrDUXD285f-aauAbV-2IkudSavW4N43XZPM5xBbEEDRLgjh8ZjY4pDiWESl8bg==";
const turnstileSiteKey = "0x4AAAAAADRyp50AYVKzplhJ";
---

<div class="sib-form rounded-lg border border-ink/10 bg-white p-5 shadow-lift sm:p-7">
  <div id="sib-form-container" class="sib-form-container">
    <div
      id="error-message"
      class="sib-form-message-panel mb-4 rounded-md border border-danger/30 bg-danger/10 p-4 text-sm font-medium text-danger"
    >
      <div class="sib-form-message-panel__text">
        <span class="sib-form-message-panel__inner-text">
          Your subscription could not be saved. Please try again.
        </span>
      </div>
    </div>

    <div
      id="success-message"
      class="sib-form-message-panel mb-4 rounded-md border border-signal/30 bg-signal/10 p-4 text-sm font-medium text-ink"
    >
      <div class="sib-form-message-panel__text">
        <span class="sib-form-message-panel__inner-text">
          Your subscription has been successful.
        </span>
      </div>
    </div>

    <div id="sib-container" class="sib-container--large sib-container--vertical">
      <form id="sib-form" method="POST" action={brevoAction} data-type="subscription">
        <div class="sib-input sib-form-block">
          <div class="form__entry entry_block">
            <div class="form__label-row">
              <label class="entry__label waitlist-label" for="EMAIL" data-required="*">Email</label>
              <div class="entry__field">
                <input
                  class="input waitlist-input"
                  type="email"
                  id="EMAIL"
                  name="EMAIL"
                  autocomplete="email"
                  placeholder="you@example.com"
                  data-required="true"
                  required
                />
              </div>
            </div>
            <label class="entry__error entry__error--primary waitlist-error"></label>
          </div>
        </div>

        <div class="sib-radiobutton-group sib-form-block mt-5">
          <div class="form__entry entry_mcq">
            <div class="form__label-row">
              <label class="entry__label waitlist-label" for="BOAT_STATUS">
                Boat status <span class="font-normal text-ink/52">(optional)</span>
              </label>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                <label class="entry__choice waitlist-choice">
                  <input type="radio" name="BOAT_STATUS" class="input_replaced" value="1" />
                  <span class="radio-button"></span>
                  <span>Owner</span>
                </label>
                <label class="entry__choice waitlist-choice">
                  <input type="radio" name="BOAT_STATUS" class="input_replaced" value="2" />
                  <span class="radio-button"></span>
                  <span>Refit or survey</span>
                </label>
                <label class="entry__choice waitlist-choice">
                  <input type="radio" name="BOAT_STATUS" class="input_replaced" value="3" />
                  <span class="radio-button"></span>
                  <span>Builder or technician</span>
                </label>
                <label class="entry__choice waitlist-choice">
                  <input type="radio" name="BOAT_STATUS" class="input_replaced" value="4" />
                  <span class="radio-button"></span>
                  <span>Researching</span>
                </label>
              </div>
            </div>
            <label class="entry__error entry__error--primary waitlist-error"></label>
          </div>
        </div>

        <div class="sib-input sib-form-block mt-5">
          <div class="form__entry entry_block">
            <div class="form__label-row">
              <label class="entry__label waitlist-label" for="NOTES">
                What feature would you love to see? <span class="font-normal text-ink/52">(optional)</span>
              </label>
              <div class="entry__field">
                <textarea
                  class="input waitlist-input min-h-28 py-3"
                  id="NOTES"
                  name="NOTES"
                  maxlength="200"
                  placeholder="Optional"
                ></textarea>
              </div>
            </div>
            <label class="entry__error entry__error--primary waitlist-error"></label>
          </div>
        </div>

        <div class="sib-captcha sib-form-block mt-5">
          <div class="form__entry entry_block">
            <div class="form__label-row">
              <script is:inline>
                window.handleCaptchaResponse = function () {
                  var captcha = document.getElementById("sib-captcha");
                  if (captcha) captcha.dispatchEvent(new Event("captchaChange"));
                };
              </script>
              <div
                class="cf-turnstile sib-visible-recaptcha"
                id="sib-captcha"
                data-sitekey={turnstileSiteKey}
                data-callback="handleCaptchaResponse"
              >
              </div>
            </div>
            <label class="entry__error entry__error--primary waitlist-error"></label>
          </div>
        </div>

        <input type="text" name="email_address_check" value="" class="input--hidden" />
        <input type="hidden" name="locale" value="en" />

        <div class="sib-form-block mt-6 flex flex-col gap-4 sm:flex-row sm:items-center">
          <button class="sib-form-block__button sib-form-block__button-with-loader waitlist-button" form="sib-form" type="submit">
            <svg class="icon clickable__icon progress-indicator__icon sib-hide-loader-icon" viewBox="0 0 512 512" aria-hidden="true">
              <path d="M460.116 373.846l-20.823-12.022c-5.541-3.199-7.54-10.159-4.663-15.874 30.137-59.886 28.343-131.652-5.386-189.946-33.641-58.394-94.896-95.833-161.827-99.676C261.028 55.961 256 50.751 256 44.352V20.309c0-6.904 5.808-12.337 12.703-11.982 83.556 4.306 160.163 50.864 202.11 123.677 42.063 72.696 44.079 162.316 6.031 236.832-3.14 6.148-10.75 8.461-16.728 5.01z"></path>
            </svg>
            Join the waitlist
          </button>
          <p class="text-sm leading-6 text-ink/62">Submits through Brevo.</p>
        </div>
      </form>
    </div>
  </div>
</div>

<script is:inline>
  window.REQUIRED_CODE_ERROR_MESSAGE = "Please choose a country code";
  window.LOCALE = "en";
  window.EMAIL_INVALID_MESSAGE = window.SMS_INVALID_MESSAGE =
    "The information provided is invalid. Please review the field format and try again.";
  window.REQUIRED_ERROR_MESSAGE = "This field cannot be left blank. ";
  window.GENERIC_INVALID_MESSAGE =
    "The information provided is invalid. Please review the field format and try again.";
  window.INVALID_NUMBER = "The information provided is invalid. Please review the field format and try again.";
  window.INVALID_DATE = "Please enter a valid date";
  window.REQUIRED_MULTISELECT_MESSAGE = "Please select at least 1 option";
  window.translation = {
    common: {
      selectedList: "{quantity} list selected",
      selectedLists: "{quantity} lists selected",
      selectedOption: "{quantity} selected",
      selectedOptions: "{quantity} selected",
    },
  };
  window.AUTOHIDE = Boolean(0);
</script>

<script is:inline defer src="https://sibforms.com/forms/end-form/build/main.js"></script>
<script is:inline defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>

<style>
  :where(.sib-form-message-panel) {
    display: none;
  }

  :global(.entry__field) {
    width: 100%;
  }

  .waitlist-label {
    display: block;
    color: rgb(12 15 18);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.5;
  }

  .waitlist-input {
    margin-top: 0.5rem;
    min-height: 3rem;
    width: 100%;
    border-radius: 0.375rem;
    border: 1px solid rgb(12 15 18 / 16%);
    background: rgb(245 247 244);
    padding: 0 1rem;
    color: rgb(12 15 18);
    font-size: 1rem;
    font-weight: 400;
    transition:
      border-color 150ms ease,
      background-color 150ms ease;
  }

  .waitlist-input::placeholder {
    color: rgb(12 15 18 / 40%);
  }

  .waitlist-input:focus {
    outline: none;
    border-color: rgb(53 183 92);
    background: white;
  }

  .waitlist-choice {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.625rem;
    border-radius: 0.375rem;
    border: 1px solid rgb(12 15 18 / 12%);
    background: rgb(245 247 244);
    padding: 0.625rem 0.75rem;
    color: rgb(12 15 18 / 72%);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .waitlist-choice input {
    accent-color: rgb(53 183 92);
  }

  .waitlist-error {
    display: block;
    margin-top: 0.5rem;
    border-radius: 0.375rem;
    color: rgb(160 33 33);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .waitlist-button {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.375rem;
    border: 0;
    background: rgb(53 183 92);
    padding: 0 1.25rem;
    color: rgb(12 15 18);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 1px 2px rgb(12 15 18 / 12%);
    transition: background-color 150ms ease;
  }

  .waitlist-button:hover {
    background: #2f9f56;
  }

  .sib-hide-loader-icon {
    display: none;
  }
</style>
