---
const brevoAction = "https://sibforms.com/serve/YOUR_BREVO_FORM_ID";
---

<form
  id="waitlist-form"
  action={brevoAction}
  method="POST"
  class="rounded-lg border border-ink/10 bg-white p-5 shadow-lift sm:p-7"
>
  <!-- Set brevoAction to the Brevo form endpoint used for signups. -->
  <label class="grid gap-2 text-sm font-semibold text-ink">
    Email
    <input
      class="min-h-12 rounded-md border border-ink/16 bg-mist px-4 text-base font-normal text-ink transition placeholder:text-ink/40 focus:border-signal focus:bg-white"
      type="email"
      name="EMAIL"
      autocomplete="email"
      placeholder="you@example.com"
      required
    />
  </label>

  <label class="mt-5 grid gap-2 text-sm font-semibold text-ink">
    Boat status <span class="font-normal text-ink/52">(optional)</span>
    <select
      class="min-h-12 rounded-md border border-ink/16 bg-mist px-4 text-base font-normal text-ink transition focus:border-signal focus:bg-white"
      name="BOAT_STATUS"
    >
      <option value="">Select one</option>
      <option value="owner">Owner</option>
      <option value="refit">Refit or survey</option>
      <option value="builder">Builder or technician</option>
      <option value="researching">Researching</option>
    </select>
  </label>

  <label class="mt-5 grid gap-2 text-sm font-semibold text-ink">
    What feature would you love to see? <span class="font-normal text-ink/52">(optional)</span>
    <textarea
      class="min-h-28 rounded-md border border-ink/16 bg-mist px-4 py-3 text-base font-normal text-ink transition placeholder:text-ink/40 focus:border-signal focus:bg-white"
      name="NOTES"
      placeholder="Optional"
    ></textarea>
  </label>

  <div aria-hidden="true" class="hidden">
    <label>
      Leave this field empty
      <input type="text" name="email_address_check" tabindex="-1" autocomplete="off" />
    </label>
  </div>
  <input type="hidden" name="locale" value="en" />

  <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center">
    <button
      class="inline-flex min-h-12 items-center justify-center rounded-md bg-signal px-5 text-base font-semibold text-ink shadow-sm transition hover:bg-[#2f9f56]"
      type="submit"
    >
      Join the waitlist
    </button>
    <p class="text-sm leading-6 text-ink/62">
      Submits through Brevo.
    </p>
  </div>
</form>
