---
interface Props {
  kicker: string;
  title: string;
  body: string;
}

const { kicker, title, body } = Astro.props;
---

<article class="rounded-lg border border-ink/10 bg-white p-6 shadow-lift">
  <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-copper">{kicker}</p>
  <h3 class="text-xl font-semibold text-ink">{title}</h3>
  <p class="mt-3 leading-7 text-ink/68">{body}</p>
</article>
