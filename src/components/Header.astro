---
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path = "") => `${base}${path.replace(/^\//, "")}`;
---

<header class="relative z-20 border-b border-ink/10 bg-mist/88 backdrop-blur">
  <div class="section-shell flex min-h-16 items-center justify-between gap-5">
    <a href={withBase()} class="flex items-center gap-3 font-semibold text-ink" aria-label="Hull Leak Monitor home">
      <span class="grid h-9 w-9 place-items-center rounded-md bg-ink text-sm font-bold text-white">HL</span>
      <span>Hull Leak Monitor</span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-medium text-ink/72 md:flex" aria-label="Primary navigation">
      <a class="transition hover:text-ink" href={withBase("#how-it-works")}>How it works</a>
      <a class="transition hover:text-ink" href={withBase("#specs")}>Specs</a>
    </nav>

    <a
      href={withBase("#waitlist")}
      class="inline-flex min-h-11 items-center justify-center rounded-md bg-ink px-4 text-sm font-semibold text-white shadow-sm transition hover:bg-panel-black focus-visible:outline-signal"
    >
      Join waitlist
    </a>
  </div>
</header>
